{% extends 'base.html.twig' %}

{% block title %}CarXMeet - Mes amis{% endblock %}

{% block body %}
    <main style="min-height: 100vh; padding: 24px;">
        <header style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 16px;">
            <h1 style="margin: 0; font-size: 22px;">Mes amis</h1>
            <a href="{{ path('app_home') }}" style="font-size: 14px; text-decoration: none; color: #111827;">
                Retour accueil
            </a>
        </header>

        {% for message in app.flashes('success') %}
            <div style="margin: 0 0 12px; padding: 10px 12px; border: 1px solid #bbf7d0; background: #f0fdf4; color: #166534; border-radius: 10px;">
                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div style="margin: 0 0 12px; padding: 10px 12px; border: 1px solid #fecaca; background: #fef2f2; color: #991b1b; border-radius: 10px;">
                {{ message }}
            </div>
        {% endfor %}

        <section style="max-width: 840px; display: grid; gap: 10px;">
            {% for f in friends %}
                {% set actions %}
                    <form method="post" action="{{ path('app_friendship_remove', { id: f.id }) }}" onsubmit="return confirm('Supprimer cet ami ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('friend_remove_' ~ f.id) }}">
                        <button type="submit" style="padding: 8px 10px; border: 0; border-radius: 10px; background: #991b1b; color: white; cursor: pointer;">
                            Supprimer
                        </button>
                    </form>
                {% endset %}

                {% include '_user_badge.html.twig' with { u: f, actions: actions } only %}
            {% else %}
                <div style="padding: 12px; border: 1px dashed #d1d5db; border-radius: 12px; color: #6b7280;">
                    Aucun ami pour le moment.
                </div>
            {% endfor %}
        </section>
    </main>
{% endblock %}

