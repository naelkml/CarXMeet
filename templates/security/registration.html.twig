{% extends "base.html.twig" %}

{% block title %}
    CarXMeet - Inscription
{% endblock %}

{% block body %}
    <div class="container py-4">
        <h1 class="mb-4">Créer un compte</h1>

        {{ form_start(form, { attr: { class: 'row g-3' } }) }}
            {% if form.vars.submitted and not form.vars.valid %}
                <div class="col-12">
                    <div class="alert alert-danger">
                        {{ form_errors(form) }}
                    </div>
                </div>
            {% endif %}

            <div class="col-md-6">{{ form_row(form.firstName) }}</div>
            <div class="col-md-6">{{ form_row(form.lastName) }}</div>
            <div class="col-md-6">{{ form_row(form.username) }}</div>
            <div class="col-md-6">{{ form_row(form.phone) }}</div>
            <div class="col-12">{{ form_row(form.email) }}</div>
            <div class="col-12">{{ form_row(form.profilePhoto) }}</div>
            <div class="col-md-6">{{ form_row(form.password.first) }}</div>
            <div class="col-md-6">{{ form_row(form.password.second) }}</div>
            <div class="col-md-4">{{ form_row(form.snapchat) }}</div>
            <div class="col-md-4">{{ form_row(form.instagram) }}</div>
            <div class="col-md-4">{{ form_row(form.twitter) }}</div>
            <div class="col-12">{{ form_row(form.tiktok) }}</div>
            <div class="col-12">{{ form_row(form.submit) }}</div>
        {{ form_end(form) }}
    </div>
{% endblock %}
