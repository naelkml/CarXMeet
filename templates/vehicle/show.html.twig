{% extends 'base.html.twig' %}

{% block title %}CarXMeet - {{ vehicle.brand }} {{ vehicle.model }}{% endblock %}

{% block body %}
    <main style="min-height: 100vh; padding: 24px;">
        <header style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 16px;">
            <div>
                <h1 style="margin: 0; font-size: 22px;">{{ vehicle.brand }} {{ vehicle.model }} ({{ vehicle.year }})</h1>
                <div style="margin-top: 6px; font-size: 13px; color: #6b7280;">
                    {{ vehicle.engine }} · {{ vehicle.preparation }}
                </div>
            </div>

            <div style="display: flex; align-items: center; gap: 10px;">
                <a href="{{ path('app_garage') }}" style="font-size: 14px; text-decoration: none; color: #111827;">
                    Retour garage
                </a>
                {% if isOwner %}
                    <a href="{{ path('app_garage_vehicle_edit', { id: vehicle.id }) }}" style="display: inline-block; padding: 10px 12px; border-radius: 10px; background: #111827; color: white; text-decoration: none;">
                        Modifier
                    </a>
                {% endif %}
            </div>
        </header>

        {% for message in app.flashes('success') %}
            <div style="margin: 0 0 12px; padding: 10px 12px; border: 1px solid #bbf7d0; background: #f0fdf4; color: #166534; border-radius: 10px;">
                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div style="margin: 0 0 12px; padding: 10px 12px; border: 1px solid #fecaca; background: #fef2f2; color: #991b1b; border-radius: 10px;">
                {{ message }}
            </div>
        {% endfor %}

        {% set cover64 = vehicle.imageBase64 %}
        {% set photos = vehicle.galleryPhotos %}
        {% if cover64 or photos|length %}
            <div class="cxm-mediaWall">
                {% if cover64 %}
                    {% set coverSrc = 'data:image/jpeg;base64,' ~ cover64 %}
                    <a class="cxm-mediaItem cxm-cover" data-cxm-lb="1" href="{{ coverSrc }}" data-cxm-caption="Cover {{ vehicle.brand }} {{ vehicle.model }}">
                        <img src="{{ coverSrc }}" alt="Cover {{ vehicle.brand }} {{ vehicle.model }}" loading="lazy" decoding="async">
                    </a>
                {% endif %}

                {% for p in photos|slice(0, 4) %}
                    {% set p64 = p.imageBase64 %}
                    {% if p64 %}
                        {% set pSrc = 'data:image/jpeg;base64,' ~ p64 %}
                        <a class="cxm-mediaItem cxm-thumb" data-cxm-lb="1" href="{{ pSrc }}" data-cxm-caption="{{ vehicle.brand }} {{ vehicle.model }}">
                            <img src="{{ pSrc }}" alt="Photo {{ vehicle.brand }} {{ vehicle.model }}" loading="lazy" decoding="async">
                        </a>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}

        <section style="padding: 14px; border: 1px solid #e5e7eb; border-radius: 12px;">
            {% if vehicle.description %}
                <p style="margin: 0; color: #374151; white-space: pre-wrap;">{{ vehicle.description }}</p>
            {% else %}
                <p style="margin: 0; color: #6b7280;">Aucune description.</p>
            {% endif %}

            {% if photos|length > 4 %}
                <div style="margin-top: 16px;">
                    <h2 style="margin: 0 0 10px; font-size: 16px;">Plus de photos</h2>
                    <div class="cxm-galleryGrid">
                        {% for p in photos|slice(4) %}
                            {% set p64 = p.imageBase64 %}
                            {% if p64 %}
                                {% set pSrc = 'data:image/jpeg;base64,' ~ p64 %}
                                <a class="cxm-mediaItem" data-cxm-lb="1" href="{{ pSrc }}" data-cxm-caption="{{ vehicle.brand }} {{ vehicle.model }}">
                                    <img src="{{ pSrc }}" alt="Photo {{ vehicle.brand }} {{ vehicle.model }}" loading="lazy" decoding="async">
                                </a>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </section>
    </main>
{% endblock %}
