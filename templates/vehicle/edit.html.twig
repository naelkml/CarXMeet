{% extends 'base.html.twig' %}

{% block title %}CarXMeet - Modifier véhicule{% endblock %}

{% block body %}
    <main style="min-height: 100vh; display: grid; place-items: center; padding: 24px;">
        <section style="width: 100%; max-width: 900px; border: 1px solid #e5e7eb; border-radius: 12px; padding: 24px;">
            <header style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 16px;">
                <h1 style="margin: 0; font-size: 22px;">Modifier véhicule</h1>
                <a href="{{ path('app_garage_vehicle_show', { id: vehicle.id }) }}" style="font-size: 14px; text-decoration: none; color: #111827;">
                    Retour
                </a>
            </header>

            {% for message in app.flashes('success') %}
                <div style="margin: 0 0 12px; padding: 10px 12px; border: 1px solid #bbf7d0; background: #f0fdf4; color: #166534; border-radius: 10px;">
                    {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div style="margin: 0 0 12px; padding: 10px 12px; border: 1px solid #fecaca; background: #fef2f2; color: #991b1b; border-radius: 10px;">
                    {{ message }}
                </div>
            {% endfor %}

            {% set img64 = vehicle.imageBase64 %}
            {% if img64 %}
                {% set coverSrc = 'data:image/jpeg;base64,' ~ img64 %}
                <a class="cxm-mediaItem cxm-cover" data-cxm-lb="1" href="{{ coverSrc }}" data-cxm-caption="Cover {{ vehicle.brand }} {{ vehicle.model }}" style="margin-bottom: 12px;">
                    <img src="{{ coverSrc }}" alt="Cover {{ vehicle.brand }} {{ vehicle.model }}" loading="lazy" decoding="async">
                </a>
            {% endif %}

            {% if vehicle.galleryPhotos|length %}
                <div style="margin: 0 0 14px; padding: 12px; border: 1px solid #e5e7eb; border-radius: 12px;">
                    <h2 style="margin: 0 0 10px; font-size: 16px;">Galerie ({{ vehicle.galleryPhotos|length }}/5)</h2>
                    <div class="cxm-galleryGrid">
                        {% for p in vehicle.galleryPhotos %}
                            {% set p64 = p.imageBase64 %}
                            <div class="cxm-tile">
                                <div class="cxm-tileMedia">
                                    {% if p64 %}
                                        {% set pSrc = 'data:image/jpeg;base64,' ~ p64 %}
                                        <a class="cxm-mediaItem" data-cxm-lb="1" href="{{ pSrc }}" data-cxm-caption="{{ vehicle.brand }} {{ vehicle.model }}">
                                            <img src="{{ pSrc }}" alt="Photo {{ vehicle.brand }} {{ vehicle.model }}" loading="lazy" decoding="async">
                                        </a>
                                    {% endif %}
                                </div>
                                <div class="cxm-tileActions">
                                    <form method="post" action="{{ path('app_garage_vehicle_photo_delete', { id: vehicle.id, photo: p.id }) }}" onsubmit="return confirm('Supprimer cette photo ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_vehicle_photo_' ~ p.id) }}">
                                        <button type="submit" style="width: 100%; padding: 8px 10px; border: 0; border-radius: 10px; background: #991b1b; color: white; cursor: pointer;">
                                            Supprimer
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {% include 'vehicle/_form.html.twig' with { form: form, button_label: 'Enregistrer' } %}
        </section>
    </main>
{% endblock %}
