{% extends 'base.html.twig' %}

{% block title %}CarXMeet - Mon garage{% endblock %}

{% block body %}
    <main style="min-height: 100vh; padding: 24px;">
        <header style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 16px;">
            <h1 style="margin: 0; font-size: 22px;">Mon garage</h1>
            <a href="{{ path('app_user_edit') }}" style="font-size: 14px; text-decoration: none; color: #111827;">
                Retour profil
            </a>
        </header>

        {% for message in app.flashes('success') %}
            <div style="margin: 0 0 12px; padding: 10px 12px; border: 1px solid #bbf7d0; background: #f0fdf4; color: #166534; border-radius: 10px;">
                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div style="margin: 0 0 12px; padding: 10px 12px; border: 1px solid #fecaca; background: #fef2f2; color: #991b1b; border-radius: 10px;">
                {{ message }}
            </div>
        {% endfor %}

        <section style="display: grid; grid-template-columns: 1fr; gap: 12px; max-width: 900px;">
            <div style="border: 1px solid #e5e7eb; border-radius: 12px; padding: 16px;">
                <h2 style="margin: 0 0 10px; font-size: 16px;">Ajouter un véhicule</h2>

                {{ form_start(form, { attr: { style: 'display: grid; gap: 12px;' } }) }}
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 10px;">
                        <div style="display: grid; gap: 6px;">
                            {{ form_label(form.brand, null, { label_attr: { style: 'font-size: 14px;' } }) }}
                            {{ form_widget(form.brand, { attr: { style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
                            {{ form_errors(form.brand) }}
                        </div>

                        <div style="display: grid; gap: 6px;">
                            {{ form_label(form.model, null, { label_attr: { style: 'font-size: 14px;' } }) }}
                            {{ form_widget(form.model, { attr: { style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
                            {{ form_errors(form.model) }}
                        </div>

                        <div style="display: grid; gap: 6px;">
                            {{ form_label(form.year, null, { label_attr: { style: 'font-size: 14px;' } }) }}
                            {{ form_widget(form.year, { attr: { placeholder: '2005', style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
                            {{ form_errors(form.year) }}
                        </div>

                        <div style="display: grid; gap: 6px;">
                            {{ form_label(form.engine, null, { label_attr: { style: 'font-size: 14px;' } }) }}
                            {{ form_widget(form.engine, { attr: { style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
                            {{ form_errors(form.engine) }}
                        </div>

                        <div style="display: grid; gap: 6px;">
                            {{ form_label(form.preparation, null, { label_attr: { style: 'font-size: 14px;' } }) }}
                            {{ form_widget(form.preparation, { attr: { style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
                            {{ form_errors(form.preparation) }}
                        </div>

                        <div style="display: grid; gap: 6px;">
                            {{ form_label(form.photos, null, { label_attr: { style: 'font-size: 14px;' } }) }}
                            {{ form_widget(form.photos, { attr: { placeholder: 'https://...', style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
                            {{ form_errors(form.photos) }}
                        </div>
                    </div>

                    <button type="submit" style="justify-self: start; padding: 10px 12px; border: 0; border-radius: 10px; background: #111827; color: white; cursor: pointer;">
                        Ajouter
                    </button>
                {{ form_end(form) }}
            </div>

            <div style="border: 1px solid #e5e7eb; border-radius: 12px; padding: 16px;">
                <h2 style="margin: 0 0 10px; font-size: 16px;">Mes véhicules</h2>

                <div style="display: grid; gap: 10px;">
                    {% for v in vehicles %}
                        <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; padding: 12px; border: 1px solid #e5e7eb; border-radius: 12px;">
                            <div>
                                <div style="font-weight: 700; color: #111827;">
                                    {{ v.brand }} {{ v.model }} ({{ v.year }})
                                </div>
                                <div style="margin-top: 4px; font-size: 13px; color: #6b7280;">
                                    {{ v.engine }} · {{ v.preparation }}
                                </div>
                            </div>

                            <form method="post" action="{{ path('app_garage_vehicle_delete', { id: v.id }) }}" onsubmit="return confirm('Supprimer ce véhicule ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_vehicle_' ~ v.id) }}">
                                <button type="submit" style="padding: 10px 12px; border: 0; border-radius: 10px; background: #991b1b; color: white; cursor: pointer;">
                                    Supprimer
                                </button>
                            </form>
                        </div>
                    {% else %}
                        <div style="padding: 12px; border: 1px dashed #d1d5db; border-radius: 12px; color: #6b7280;">
                            Aucun véhicule pour le moment.
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    </main>
{% endblock %}

