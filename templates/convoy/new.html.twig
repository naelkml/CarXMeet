{% extends 'base.html.twig' %}

{% block title %}CarXMeet - Nouveau convoi{% endblock %}

{% block body %}
    <main style="min-height: 100vh; display: grid; place-items: center; padding: 24px;">
        <section style="width: 100%; max-width: 720px; border: 1px solid #e5e7eb; border-radius: 12px; padding: 24px;">
            <header style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 16px;">
                <h1 style="margin: 0; font-size: 22px;">Créer un convoi</h1>
                <a href="{{ path('app_events_show', { id: event.id }) }}" style="font-size: 14px; text-decoration: none; color: #111827;">
                    Retour évènement
                </a>
            </header>

            {% for message in app.flashes('success') %}
                <div style="margin: 0 0 12px; padding: 10px 12px; border: 1px solid #bbf7d0; background: #f0fdf4; color: #166534; border-radius: 10px;">
                    {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div style="margin: 0 0 12px; padding: 10px 12px; border: 1px solid #fecaca; background: #fef2f2; color: #991b1b; border-radius: 10px;">
                    {{ message }}
                </div>
            {% endfor %}

            {{ form_start(form, { attr: { style: 'display: grid; gap: 12px;' } }) }}
                <div style="display: grid; gap: 6px;">
                    {{ form_label(form.departureLocation, null, { label_attr: { style: 'font-size: 14px;' } }) }}
                    {{ form_widget(form.departureLocation, { attr: { style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
                    {{ form_errors(form.departureLocation) }}
                </div>

                <div style="display: grid; gap: 6px;">
                    {{ form_label(form.departureDate, null, { label_attr: { style: 'font-size: 14px;' } }) }}
                    {{ form_widget(form.departureDate, { attr: { placeholder: '2026-04-16', style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
                    {{ form_errors(form.departureDate) }}
                </div>

                <div style="display: grid; gap: 6px;">
                    {{ form_label(form.departureTime, null, { label_attr: { style: 'font-size: 14px;' } }) }}
                    {{ form_widget(form.departureTime, { attr: { placeholder: '18:30', style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
                    {{ form_errors(form.departureTime) }}
                </div>

                <button type="submit" style="justify-self: start; padding: 10px 12px; border: 0; border-radius: 10px; background: #111827; color: white; cursor: pointer;">
                    Créer
                </button>
            {{ form_end(form) }}
        </section>
    </main>
{% endblock %}

