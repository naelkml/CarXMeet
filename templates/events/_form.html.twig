{{ form_start(form, { attr: { style: 'display: grid; gap: 12px;' } }) }}
    <div style="display: grid; gap: 6px;">
        {{ form_label(form.title, null, { label_attr: { style: 'font-size: 14px;' } }) }}
        {{ form_widget(form.title, { attr: { style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
        {{ form_errors(form.title) }}
    </div>

    <div style="display: grid; gap: 6px;">
        {{ form_label(form.organisateur, null, { label_attr: { style: 'font-size: 14px;' } }) }}
        {{ form_widget(form.organisateur, { attr: { style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
        {{ form_errors(form.organisateur) }}
    </div>

    <div style="display: grid; gap: 6px;">
        {{ form_label(form.description, null, { label_attr: { style: 'font-size: 14px;' } }) }}
        {{ form_widget(form.description, { attr: { rows: 6, style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
        {{ form_errors(form.description) }}
    </div>

    <div style="display: grid; gap: 6px;">
        {{ form_label(form.type, null, { label_attr: { style: 'font-size: 14px;' } }) }}
        {{ form_widget(form.type, { attr: { style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
        {{ form_errors(form.type) }}
    </div>

    <div style="display: grid; gap: 6px;">
        {{ form_label(form.Date, null, { label_attr: { style: 'font-size: 14px;' } }) }}
        {{ form_widget(form.Date, { attr: { placeholder: '2026-03-18', style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
        {{ form_errors(form.Date) }}
    </div>

    <div style="display: grid; gap: 6px;">
        {{ form_label(form.location, null, { label_attr: { style: 'font-size: 14px;' } }) }}
        {{ form_widget(form.location, { attr: { style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
        {{ form_errors(form.location) }}
    </div>

    <div style="display: grid; gap: 6px;">
        {{ form_label(form.regionID, null, { label_attr: { style: 'font-size: 14px;' } }) }}
        {{ form_widget(form.regionID, { attr: { style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
        {{ form_errors(form.regionID) }}
    </div>

    <div style="display: grid; gap: 6px;">
        {{ form_label(form.coverPhoto, null, { label_attr: { style: 'font-size: 14px;' } }) }}
        {{ form_widget(form.coverPhoto, { attr: { accept: 'image/*', style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
        {{ form_errors(form.coverPhoto) }}
    </div>

    <div style="display: grid; gap: 6px;">
        {{ form_label(form.gallery, null, { label_attr: { style: 'font-size: 14px;' } }) }}
        {{ form_widget(form.gallery, { attr: { style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
        {{ form_errors(form.gallery) }}
    </div>

    <div style="display: grid; gap: 6px;">
        {{ form_label(form.ratingAverage, null, { label_attr: { style: 'font-size: 14px;' } }) }}
        {{ form_widget(form.ratingAverage, { attr: { placeholder: '0', style: 'padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 10px;' } }) }}
        {{ form_errors(form.ratingAverage) }}
    </div>

    <button type="submit" style="padding: 10px 12px; border: 0; border-radius: 10px; background: #111827; color: white; cursor: pointer;">
        Enregistrer
    </button>
{{ form_end(form) }}
