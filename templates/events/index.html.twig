{% extends 'base.html.twig' %}

{% block title %}
    CarXMeet - Événements
{% endblock %}

{% block body %}
    <style>
        .event-card {
            display: grid;
            grid-template-columns: 120px 1fr auto;
            gap: 12px;
            align-items: start;
            padding: 14px;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
        }
        .event-media {
            width: 120px;
            height: 90px;
            border-radius: 10px;
            overflow: hidden;
            background: linear-gradient(135deg, #111827 0%, #374151 50%, #111827 100%);
            border: 1px solid #e5e7eb;
        }
        .event-media img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
        @media (max-width: 520px) {
            .event-card {
                grid-template-columns: 90px 1fr;
            }
            .event-media {
                width: 90px;
                height: 72px;
            }
        }
    </style>

    <main style="min-height: 100vh; padding: 24px;">
        <header style="display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 16px;">
            <div>
                <h1 style="margin: 0; font-size: 22px;">Événements</h1>
                {% if region %}
                    <div style="margin-top: 4px; font-size: 13px; color: #6b7280;">
                        Région: <strong style="color: #111827;">{{ region.name }}</strong>
                    </div>
                {% endif %}
            </div>

            <div style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap; justify-content: flex-end;">
                <form method="get" style="display: flex; align-items: center; gap: 8px;">
                    {% if region %}
                        <input type="hidden" name="region" value="{{ region.id }}">
                    {% endif %}
                    <label for="sort" style="font-size: 14px; color: #374151;">Trier:</label>
                    <select id="sort" name="sort" style="padding: 8px 10px; border: 1px solid #d1d5db; border-radius: 10px; background: white;">
                        <option value="date_asc" {{ sort == 'date_asc' ? 'selected' : '' }}>Date (croissante)</option>
                        <option value="date_desc" {{ sort == 'date_desc' ? 'selected' : '' }}>Date (décroissante)</option>
                        <option value="type_asc" {{ sort == 'type_asc' ? 'selected' : '' }}>Type (A → Z)</option>
                        <option value="type_desc" {{ sort == 'type_desc' ? 'selected' : '' }}>Type (Z → A)</option>
                        <option value="rating_desc" {{ sort == 'rating_desc' ? 'selected' : '' }}>Notation (meilleure)</option>
                        <option value="rating_asc" {{ sort == 'rating_asc' ? 'selected' : '' }}>Notation (moins bonne)</option>
                        <option value="created_desc" {{ sort == 'created_desc' ? 'selected' : '' }}>Ancienneté (nouveaux)</option>
                        <option value="created_asc" {{ sort == 'created_asc' ? 'selected' : '' }}>Ancienneté (anciens)</option>
                    </select>
                    <button type="submit" style="padding: 8px 10px; border: 0; border-radius: 10px; background: #111827; color: white; cursor: pointer;">
                        OK
                    </button>
                </form>

                <a href="{{ path('app_home') }}" style="font-size: 14px; text-decoration: none; color: #111827;">
                    Retour accueil
                </a>

                {% if is_granted('ROLE_EVENT_MANAGER') %}
                    <a href="{{ path('app_events_new') }}" style="display: inline-block; padding: 10px 12px; border-radius: 10px; background: #111827; color: white; text-decoration: none;">
                        Créer un événement
                    </a>
                {% endif %}
            </div>
        </header>

        {% for message in app.flashes('success') %}
            <div style="margin: 0 0 12px; padding: 10px 12px; border: 1px solid #bbf7d0; background: #f0fdf4; color: #166534; border-radius: 10px;">
                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div style="margin: 0 0 12px; padding: 10px 12px; border: 1px solid #fecaca; background: #fef2f2; color: #991b1b; border-radius: 10px;">
                {{ message }}
            </div>
        {% endfor %}

        <div style="display: grid; gap: 10px;">
            {% for event in events %}
                {% set img64 = event.imageBase64 %}

                <article class="event-card">
                    <a class="event-media" href="{{ path('app_events_show', { id: event.id }) }}" style="text-decoration: none;">
                        {% if img64 %}
                            <img src="data:image/jpeg;base64,{{ img64 }}" alt="Cover {{ event.title }}" loading="lazy" decoding="async">
                        {% else %}
                            <span style="width: 100%; height: 100%; display: grid; place-items: center; color: #e5e7eb; font-size: 12px;">
                                Cover
                            </span>
                        {% endif %}
                    </a>

                    <div>
                        <div>
                            <a href="{{ path('app_events_show', { id: event.id }) }}" style="text-decoration: none; color: #111827;">
                                <h2 style="margin: 0; font-size: 18px;">{{ event.title }}</h2>
                            </a>
                            <div style="margin-top: 6px; font-size: 13px; color: #6b7280;">
                                {{ event.date }} · {{ event.location }} · {{ event.type }}
                                {% if event.regionID %}
                                    · {{ event.regionID.name }}
                                {% endif %}
                            </div>
                        </div>

                        <p style="margin: 10px 0 0; color: #374151;">
                            {{ event.description|slice(0, 200) }}{% if event.description|length > 200 %}…{% endif %}
                        </p>

                        <div style="margin-top: 8px; font-size: 13px; color: #6b7280;">
                            Note moyenne:
                            <strong style="color: #111827;">
                                {{ event.ratingAverage ? event.ratingAverage : '0' }}/5
                            </strong>
                        </div>
                    </div>

                    {% if is_granted('ROLE_EVENT_MANAGER') %}
                        <div style="display: grid; gap: 10px; justify-items: end;">
                            <a href="{{ path('app_events_edit', { id: event.id }) }}" style="font-size: 14px; text-decoration: none; color: #111827;">
                                Modifier
                            </a>
                            <form method="post" action="{{ path('app_events_delete', { id: event.id }) }}" onsubmit="return confirm('Supprimer cet événement ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_event_' ~ event.id) }}">
                                <button type="submit" style="padding: 10px 12px; border: 0; border-radius: 10px; background: #991b1b; color: white; cursor: pointer;">
                                    Supprimer
                                </button>
                            </form>
                        </div>
                    {% endif %}

                </article>
            {% else %}
                <div style="padding: 12px; border: 1px dashed #d1d5db; border-radius: 12px; color: #6b7280;">
                    Aucun événement pour le moment.
                </div>
            {% endfor %}
        </div>
    </main>
{% endblock %}
