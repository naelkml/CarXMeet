<div style="background:#f1f5f9;padding:50px 15px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">

  <div style="max-width:600px;margin:auto;background:white;border-radius:18px;overflow:hidden;box-shadow:0 18px 45px rgba(0,0,0,0.08);">

<div style="padding:28px 30px;border-bottom:1px solid #eef2f7;text-align:center;">
  <h1 style="margin:0;font-size:24px;font-weight:600;color:#0f172a;">
    CarXMeet
  </h1>
</div>

<div style="padding:40px 35px;color:#334155;">

  <h2 style="margin-top:0;font-size:22px;font-weight:600;color:#0f172a;">
    Confirme ton adresse email
  </h2>

  <p style="font-size:16px;line-height:1.6;margin-top:18px;">
    Merci pour ton inscription sur <strong>CarXMeet</strong>.
    Pour activer ton compte et rejoindre la communauté automobile,
    confirme simplement ton adresse email.
  </p>

  <div style="text-align:center;margin:40px 0;">
    <a href="{{ signedUrl }}"
       style="display:inline-block;
              background:#0d6efd;
              color:white;
              text-decoration:none;
              padding:16px 38px;
              font-size:16px;
              font-weight:600;
              border-radius:12px;
              box-shadow:0 10px 25px rgba(13,110,253,0.35);">
      Confirmer mon email
    </a>
  </div>

  <p style="text-align:center;font-size:14px;color:#64748b;">
    Ce lien expirera
    {{ expiresAtMessageKey|trans(expiresAtMessageData, 'VerifyEmailBundle') }}
  </p>

  <div style="height:1px;background:#e2e8f0;margin:35px 0;"></div>

  <!-- Help text -->
  <p style="font-size:13px;color:#94a3b8;text-align:center;line-height:1.6;">
    Si tu n’as pas créé de compte sur CarXMeet,
    tu peux ignorer cet email en toute sécurité.
  </p>

</div>

<div style="background:#f8fafc;padding:20px;text-align:center;font-size:13px;color:#94a3b8;">
  © {{ "now"|date("Y") }} CarXMeet · Vérification sécurisée du compte
</div>

  </div>

</div>
